      "source": [
        "# the problem is that the L.sort() tries to compare the strings\n",
        "# and inetgers directly which python does'nt allow thats why it gives an error\n",
        "# to fix this issue we will give sort() a key which will convert\n",
        "# everything to a common, comparable form\n",
        "\n",
        "L = [\"Ram\",1,\"Shyam\",2,\"Aman\",3]\n",
        "print(L)\n",
        "L.sort(key=str)\n",
        "print(L)"
